<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.geometry.Insets?>

<!-- ════════════════════════════════════════════════════════════
     GAME VIEW (narrativa)
     fx:id invariati: bgRegion, areaLabel, playerStatsLabel,
       eventTitleLabel, eventDescriptionArea, eventImageView,
       eventImageCaption, skipBtn, choicesBox, equipOverlay,
       weaponSlotCard, armorSlotCard, equipStatsLabel, equipBagGrid
     Handler invariati: #onBuild #onSkipAnimation #onEquipmentClose
     ════════════════════════════════════════════════════════════ -->
<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="it.unicam.cs.mpgc.rpg126115.controller.GameController"
           styleClass="root-pane">

    <!-- Layer 1: sfondo dinamico dell'area (classe bg-* impostata dal controller) -->
    <Region fx:id="bgRegion" maxWidth="Infinity" maxHeight="Infinity"/>

    <!-- Layer 2: vignettatura cinematografica -->
    <Region maxWidth="Infinity" maxHeight="Infinity"
            styleClass="game-overlay-vignette" mouseTransparent="true"/>

    <!-- Layer 2b: gradiente di profondità inferiore -->
    <Region maxWidth="Infinity" maxHeight="Infinity" mouseTransparent="true"
            styleClass="bottom-fade"/>

    <!-- Layer 2c: oscuramento header -->
    <Region maxWidth="Infinity" maxHeight="Infinity" mouseTransparent="true"
            styleClass="top-fade"/>

    <!-- Layer 3: contenuto UI -->
    <BorderPane styleClass="transparent-pane">

        <!-- TOP BAR: area + statistiche giocatore -->
        <top>
            <HBox spacing="12" styleClass="top-bar" alignment="CENTER_LEFT">
                <Label text="◈" styleClass="top-bar-icon"/>
                <Label fx:id="areaLabel" styleClass="area-label"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="playerStatsLabel" styleClass="stats-label"/>
            </HBox>
        </top>

        <!-- CENTER: ritratto + pannello narrativo -->
        <center>
            <HBox spacing="14">
                <padding><Insets top="14" right="18" bottom="8" left="18"/></padding>

                <!-- ── RITRATTO PERSONAGGIO ── -->
                <VBox styleClass="char-portrait-panel"
                      alignment="BOTTOM_CENTER" prefWidth="215" minWidth="200">
                    <ImageView fx:id="eventImageView"
                               fitWidth="196" fitHeight="360"
                               preserveRatio="true" smooth="true"/>
                    <Label fx:id="eventImageCaption"
                           maxWidth="196" wrapText="true"
                           styleClass="portrait-caption"/>
                    <Region prefHeight="10"/>
                    <Button text="⚔  BUILD" onAction="#onBuild"
                            styleClass="build-btn" maxWidth="Infinity"/>
                </VBox>

                <!-- ── PANNELLO NARRATIVO ── -->
                <VBox spacing="0" HBox.hgrow="ALWAYS" styleClass="narrative-panel">

                    <!-- Barra del titolo -->
                    <HBox styleClass="narrative-title-bar" alignment="CENTER_LEFT" spacing="10">
                        <Label text="◆" styleClass="narrative-title-icon"/>
                        <Label fx:id="eventTitleLabel" styleClass="event-title-label"
                               HBox.hgrow="ALWAYS"/>
                    </HBox>

                    <!-- Testo della storia (typewriter) -->
                    <TextArea fx:id="eventDescriptionArea"
                              editable="false" wrapText="true"
                              styleClass="narrative-area"
                              VBox.vgrow="ALWAYS"
                              focusTraversable="false"/>

                    <!-- Footer: controlli skip -->
                    <HBox styleClass="narrative-footer" alignment="CENTER_RIGHT" spacing="12">
                        <Label styleClass="skip-hint" text="clicca sul testo per saltare"/>
                        <Button fx:id="skipBtn" text="▶▶  Salta"
                                onAction="#onSkipAnimation"
                                styleClass="skip-btn"/>
                    </HBox>
                </VBox>
            </HBox>
        </center>

        <!-- BOTTOM: pulsanti di scelta -->
        <bottom>
            <VBox styleClass="choices-section" spacing="8">
                <HBox alignment="CENTER" spacing="16">
                    <Region HBox.hgrow="ALWAYS" styleClass="divider-gold-soft"/>
                    <Label text="⬥  COSA FAI?  ⬥" styleClass="section-label"/>
                    <Region HBox.hgrow="ALWAYS" styleClass="divider-gold-soft"/>
                </HBox>
                <!-- Pulsanti dinamici iniettati dal GameController -->
                <VBox fx:id="choicesBox" spacing="10"/>
            </VBox>
        </bottom>
    </BorderPane>

    <!-- OVERLAY BUILD / EQUIPAGGIAMENTO -->
    <VBox fx:id="equipOverlay" visible="false"
          maxWidth="Infinity" maxHeight="Infinity" alignment="CENTER"
          styleClass="scrim-modal">
        <VBox styleClass="equip-panel" maxWidth="860" alignment="CENTER" spacing="0">
            <padding><Insets top="28" right="36" bottom="28" left="36"/></padding>
            <Label text="⚔  BUILD — EQUIPAGGIAMENTO" styleClass="equip-panel-title" maxWidth="Infinity"/>
            <Region prefHeight="4"/>
            <Label text="Clicca un oggetto nel zaino per equipaggiarlo  ·  Clicca uno slot equipaggiato per rimuoverlo"
                   styleClass="equip-panel-hint" maxWidth="Infinity"/>
            <Region prefHeight="22"/>

            <!-- Riga slot + statistiche -->
            <HBox spacing="20" alignment="CENTER">
                <VBox alignment="CENTER" spacing="8" prefWidth="210">
                    <Label text="⚔  ARMA" styleClass="equip-slot-label"/>
                    <VBox fx:id="weaponSlotCard" styleClass="equip-slot-card"
                          alignment="CENTER" prefHeight="115" maxWidth="210">
                        <padding><Insets top="10" right="12" bottom="10" left="12"/></padding>
                    </VBox>
                </VBox>
                <VBox alignment="CENTER" spacing="8" prefWidth="210">
                    <Label text="🛡  ARMATURA" styleClass="equip-slot-label"/>
                    <VBox fx:id="armorSlotCard" styleClass="equip-slot-card"
                          alignment="CENTER" prefHeight="115" maxWidth="210">
                        <padding><Insets top="10" right="12" bottom="10" left="12"/></padding>
                    </VBox>
                </VBox>
                <VBox alignment="CENTER_LEFT" spacing="8" HBox.hgrow="ALWAYS">
                    <Label text="📊  STATISTICHE" styleClass="equip-slot-label"/>
                    <VBox styleClass="equip-stats-box" alignment="CENTER_LEFT" spacing="5">
                        <padding><Insets top="14" right="18" bottom="14" left="18"/></padding>
                        <Label fx:id="equipStatsLabel" styleClass="equip-stats-text"
                               wrapText="true" maxWidth="300"/>
                    </VBox>
                </VBox>
            </HBox>

            <Region prefHeight="24"/>
            <Label text="─────  Zaino  ─────" styleClass="equip-bag-title" maxWidth="Infinity"/>
            <Region prefHeight="12"/>
            <FlowPane fx:id="equipBagGrid" hgap="12" vgap="12" alignment="CENTER" prefWrapLength="780"/>
            <Region prefHeight="20"/>
            <HBox alignment="CENTER">
                <Button text="✖  Chiudi" onAction="#onEquipmentClose" styleClass="cancel-selection-btn"/>
            </HBox>
        </VBox>
    </VBox>

</StackPane>
