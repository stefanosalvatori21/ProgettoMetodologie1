<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<StackPane xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="it.unicam.cs.mpgc.rpg126115.controller.VictoryController"
           styleClass="root-pane" prefWidth="1600" prefHeight="900">

    <!-- Sfondo Seireitei + scrim -->
    <Region styleClass="bg-seireitei"/>
    <Region style="-fx-background-color: rgba(6,6,10,0.74);"/>

    <!-- Contenuto centrale -->
    <VBox fx:id="rootVBox" alignment="CENTER" spacing="18"
          style="-fx-padding: 36 80 36 80;">

        <!-- Icona decorativa -->
        <Label text="⚔"
               style="-fx-font-size: 48px;
                      -fx-text-fill: rgba(255,215,0,0.88);
                      -fx-effect: dropshadow(gaussian, rgba(255,215,0,0.72), 28, 0.48, 0, 0);"/>

        <!-- Titolo principale -->
        <Label fx:id="victoryTitleLabel" text="L'ALBA DEI TRE MONDI"
               style="-fx-font-family: 'Impact', 'Arial Black', sans-serif;
                      -fx-font-size: 52px;
                      -fx-text-fill: #FFD700;
                      -fx-alignment: CENTER;
                      -fx-text-alignment: CENTER;
                      -fx-effect: dropshadow(gaussian, rgba(255,215,0,0.90), 42, 0.62, 0, 0);"/>

        <!-- Divider oro -->
        <Region maxWidth="580"
                style="-fx-background-color: linear-gradient(to right, transparent, rgba(255,215,0,0.60), transparent);
                       -fx-pref-height: 1; -fx-max-height: 1;"/>

        <!-- Info personaggio -->
        <Label fx:id="playerInfoLabel"
               style="-fx-font-size: 13px;
                      -fx-text-fill: rgba(0,210,255,0.90);
                      -fx-font-weight: bold;
                      -fx-alignment: CENTER;
                      -fx-text-alignment: CENTER;"/>

        <!-- Pannello testo storia -->
        <VBox alignment="CENTER" maxWidth="800"
              style="-fx-background-color: rgba(10,10,13,0.88);
                     -fx-border-color: rgba(255,215,0,0.38);
                     -fx-border-width: 1;
                     -fx-padding: 22 32 22 32;">
            <TextArea fx:id="storyTextArea" editable="false" wrapText="true"
                      prefRowCount="7" focusTraversable="false"
                      styleClass="narrative-area"
                      style="-fx-font-size: 15px; -fx-background-color: transparent;"/>
        </VBox>

        <!-- Divider oro -->
        <Region maxWidth="580"
                style="-fx-background-color: linear-gradient(to right, transparent, rgba(255,215,0,0.60), transparent);
                       -fx-pref-height: 1; -fx-max-height: 1;"/>

        <!-- Pulsanti -->
        <HBox alignment="CENTER" spacing="36">
            <Button text="◀  Menu Principale" onAction="#onMainMenu" styleClass="menu-button-danger"/>
            <Button text="↺  Nuova Avventura"  onAction="#onNewGame"  styleClass="menu-button"/>
        </HBox>

    </VBox>

</StackPane>
