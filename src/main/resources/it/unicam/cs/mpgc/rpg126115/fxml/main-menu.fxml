<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>

<!-- ════════════════════════════════════════════════════════════
     MAIN MENU — Layer 1: sfondo · Layer 2: scrim · Layer 3: UI
     Handler invariati: #onNewGame · #onLoadGame · #onQuit
     ════════════════════════════════════════════════════════════ -->
<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="it.unicam.cs.mpgc.rpg126115.controller.MainMenuController"
           styleClass="root-pane">

    <!-- Layer 1: sfondo -->
    <Region styleClass="bg-menu" maxWidth="Infinity" maxHeight="Infinity"/>

    <!-- Layer 2: scrim scuro -->
    <Region styleClass="scrim" maxWidth="Infinity" maxHeight="Infinity"
            mouseTransparent="true"/>

    <!-- Layer 3: contenuto -->
    <VBox alignment="CENTER" spacing="0"
          maxWidth="Infinity" maxHeight="Infinity"
          styleClass="menu-content">

        <Region prefHeight="56"/>

        <ImageView fitWidth="560" preserveRatio="true" smooth="true">
            <image><Image url="@../images/bleach_logo.png"/></image>
        </ImageView>

        <Region prefHeight="20"/>
        <Region styleClass="divider-gold" maxWidth="420"/>
        <Region prefHeight="34"/>

        <VBox spacing="18" alignment="CENTER">
            <Button text="⚔   NUOVA PARTITA"
                    onAction="#onNewGame"
                    styleClass="menu-button" prefWidth="380"/>

            <Button text="📂   CARICA PARTITA"
                    onAction="#onLoadGame"
                    styleClass="menu-button" prefWidth="380"/>
        </VBox>

        <Region prefHeight="26"/>

        <Button text="✖   ESCI"
                onAction="#onQuit"
                styleClass="menu-button-danger" prefWidth="380"/>

        <Region prefHeight="1" maxHeight="Infinity"/>

        <Label text="Università di Camerino · Metodologie di Programmazione 2025/2026"
               styleClass="menu-footer"/>
        <Region prefHeight="20"/>
    </VBox>
</StackPane>
